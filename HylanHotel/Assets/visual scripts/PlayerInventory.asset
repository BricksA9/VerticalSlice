      for soda can","comment":null,"color":{"r":0.0,"g":0.0,"b":0.0,"a":1.0},"guid":"ac6f7d30-25ee-429d-b9cd-3af0b895b5de","$version":"A","$type":"Unity.VisualScripting.GraphGroup"},{"position":{"xMin":690.0,"yMin":-810.0,"xMax":2130.0,"yMax":206.0},"label":"logic
      for bat","comment":null,"color":{"r":0.0,"g":0.0,"b":0.0,"a":1.0},"guid":"4e247cba-28f9-448a-ac0f-13a373180244","$version":"A","$type":"Unity.VisualScripting.GraphGroup"},{"position":{"xMin":2488.0,"yMin":709.0,"xMax":3265.0,"yMax":1372.0},"label":"remove
